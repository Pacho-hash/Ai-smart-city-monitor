        -80
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.candidates[0].content.parts[0].text }}",
              "operation": "contains",
              "value2": "ALERT"
            }
          ]
        }
      },
      "id": "38c9b83f-1de8-4972-9ae3-dcb3f1105a86",
