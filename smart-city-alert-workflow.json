              "id": "2d8f9c8d-1234-4a4b-9c8d-1234567890ab",
              "name": "ai_prompt",
              "value": "={{ 'You are a Smart City Operations AI for Riyadh, Saudi Arabia. Analyze this raw weather data: ' + JSON.stringify($json) + '. If conditions are extreme (Temperature over 45°C, high winds, sandstorms, or heavy rain), output exactly \\'ALERT:\\' followed by a short warning for logistics teams. If conditions are fine, output exactly \\'SAFE: Conditions are normal for city operations.\\' Do not use markdown.' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "513ab9c6-3c7e-42dd-8eb7-c5bcd64ca71d",
      "name": "Format AI Prompt",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -1312,
        -80
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=YOUR_GEMINI_API_KEY",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": {{(JSON.stringify($json.ai_prompt))}}\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
      "id": "316135f5-f0c9-4174-ad31-15e6c8a9f813",
      "name": "Gemini AI Analysis",
      "type": "n8n-nodes-base.httpRequest",
